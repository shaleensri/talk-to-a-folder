// Prisma schema for Talk to a Folder
// Uses SQLite for dev (zero external services). Swap DATABASE_URL to postgres:// for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth adapter tables)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  folders       IndexedFolder[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Core domain models
// ---------------------------------------------------------------------------

model IndexedFolder {
  id          String   @id @default(cuid())
  name        String
  driveUrl    String
  folderId    String                    // Google Drive folder ID
  status      String   @default("idle") // idle | ingesting | indexed | error
  fileCount   Int      @default(0)
  chunkCount  Int      @default(0)
  lastIndexed DateTime?
  errorMessage String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files DriveFile[]
  chunks TextChunk[]
  sessions ChatSession[]
}

model DriveFile {
  id          String  @id @default(cuid())
  folderId    String
  driveFileId String
  name        String
  mimeType    String
  size        Int?
  status      String  @default("pending") // pending | parsing | indexed | error | skipped
  errorMessage String?
  parsedAt    DateTime?
  createdAt   DateTime @default(now())

  folder IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  chunks TextChunk[]
}

model TextChunk {
  id         String  @id @default(cuid())
  folderId   String
  fileId     String
  text       String
  chunkIndex Int
  startChar  Int
  endChar    Int
  // Embedding stored as JSON array of floats (SQLite compat)
  // For Postgres, use pgvector extension instead
  embedding  String? // JSON: number[]
  createdAt  DateTime @default(now())

  folder IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  file   DriveFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String   @id @default(cuid())
  folderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder   IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user | assistant
  content   String
  // Structured data stored as JSON strings
  citations String?  // JSON: Citation[]
  metadata  String?  // JSON: AnswerMetadata
  debugInfo String?  // JSON: RetrievalDebugInfo
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
