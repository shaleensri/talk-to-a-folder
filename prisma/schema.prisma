// Prisma schema for Talk to a Folder

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth adapter tables)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  folders       IndexedFolder[]
  chatSessions  ChatSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Core domain models
// ---------------------------------------------------------------------------

model IndexedFolder {
  id           String   @id @default(cuid())
  name         String
  driveUrl     String
  folderId     String                    // Google Drive folder ID
  status       String   @default("idle") // idle | ingesting | indexed | error
  fileCount    Int      @default(0)
  chunkCount   Int      @default(0)
  lastIndexed  DateTime?
  errorMessage String?
  progressJson String?  // JSON: IngestionProgress — written during ingestion for cross-instance polling
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files DriveFile[]
  chunks TextChunk[]
  chatSessionFolders ChatSessionFolder[]
}

model DriveFile {
  id          String  @id @default(cuid())
  folderId    String
  driveFileId String
  name        String
  mimeType    String
  size        Int?
  status      String  @default("pending") // pending | parsing | indexed | error | skipped
  errorMessage String?
  summary     String? // LLM-generated 3-5 sentence summary of full file content
  parsedAt    DateTime?
  createdAt   DateTime @default(now())

  folder IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  chunks TextChunk[]
}

model TextChunk {
  id         String  @id @default(cuid())
  folderId   String
  fileId     String
  text       String
  chunkIndex Int
  startChar  Int
  endChar    Int
  // Embedding stored as JSON array of floats.
  // Future: migrate to pgvector for native vector similarity queries.
  embedding  String? // JSON: number[]
  createdAt  DateTime @default(now())

  folder IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  file   DriveFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

// A chat session can reference multiple folders (many-to-many via ChatSessionFolder)
model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  folders  ChatSessionFolder[]
  messages ChatMessage[]
}

// Join table: which folders a chat session references
model ChatSessionFolder {
  sessionId String
  folderId  String
  addedAt   DateTime @default(now())

  session ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  folder  IndexedFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([sessionId, folderId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user | assistant
  content   String
  // Structured data stored as JSON strings
  citations String?  // JSON: Citation[]
  metadata  String?  // JSON: AnswerMetadata
  debugInfo String?  // JSON: RetrievalDebugInfo
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
